# Environment Configuration Template (Backend)
NODE_ENV=production
PORT=5000

# Database Configuration
# MongoDB Connection String (must be a replica set for transaction support, e.g. MongoDB Atlas)
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.example.mongodb.net/mamafrankey

# Authentication
# Secret key for signing JSON Web Tokens (JWT)
JWT_SECRET=your_super_secure_random_jwt_secret_key_here

# Third-Party Integrations
# Cloudinary credentials for menu item image uploads
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
